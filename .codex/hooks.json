{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/docs-after-edit.sh\"",
            "statusMessage": "Checking docs harness for drift"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/docs-on-stop.sh\"",
            "timeout": 30,
            "statusMessage": "Final docs harness check"
          }
        ]
      }
    ]
  }
}
