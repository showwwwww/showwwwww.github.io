{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "command": ".cursor/hooks/docs-after-edit.sh",
        "matcher": "^(Write|StrReplace|EditNotebook)$"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/docs-on-stop.sh",
        "loop_limit": 1
      }
    ]
  }
}
